# Server
PORT=3000
NODE_ENV=development

# Admin auth fallback for local development only
ADMIN_PASSWORD=change-me

# Firebase web client config
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
VITE_ALLOWED_ADMIN_EMAILS=admin@example.com

# Firebase admin credentials for the server
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# Server-side Gemini AI key
GEMINI_API_KEY=your_gemini_api_key_here

# App URL for metadata and deployment links
APP_URL=http://localhost:3000
